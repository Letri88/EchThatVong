@{
    ViewData["title"] = "List Wishlist";
    var key = 0;
}

<div class="container mt-5">
    <h3 class="text-center mb-4 fw-bold text-danger">
        <i class="bi bi-heart-fill"></i> Danh sách sản phẩm yêu thích
    </h3>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover align-middle text-center">
            <thead class="table-danger">
                <tr>
                    <th>#</th>
                    <th>Tên sản phẩm</th>
                    <th>Mô tả</th>
                    <th>Giá</th>
                    <th>Hình ảnh</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var wishlist_product in Model)
                {
                    key++;
                    <tr>
                        <td class="fw-bold">@key</td>
                        <td class="text-primary fw-semibold">@wishlist_product.Product.Name</td>
                        <td class="text-muted text-start" style="max-width: 250px;">
                            @Html.Raw(@wishlist_product.Product.Description)
                        </td>
                        <td class="text-danger fw-bold">
                            @wishlist_product.Product.Price.ToString("#,##0 VNĐ")
                        </td>
                        <td>
                            <img src="~/media/products/@wishlist_product.Product.Image"
                                 alt="@wishlist_product.Product.Name"
                                 class="img-thumbnail rounded shadow-sm"
                                 style="width: 100px; height: 120px; object-fit: cover;" />
                        </td>
                        <td>
                            <a class="btn btn-outline-danger btn-sm px-3 py-1 confirmDeletion"
                               asp-action="DeleteWishlist"
                               asp-controller="Home"
                               asp-route-Id="@wishlist_product.Wishlists.Id">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    h3 i {
        margin-right: 8px;
    }

    .table thead th {
        background-color: #ffcccc;
        color: #8b0000;
    }

    .table tbody tr:hover {
        background-color: #fff5f5;
        transition: background-color 0.3s ease;
    }

    .btn-outline-danger:hover {
        background-color: #dc3545;
        color: white;
        transition: all 0.3s ease;
    }
</style>
