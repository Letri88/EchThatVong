@{
    ViewData["Title"] = "Theo dõi đơn hàng";
}

<h3>Theo dõi đơn hàng</h3>
<p class="text-muted">Nhập mã đơn hàng (Orders_Code) được gửi trong email để xem trạng thái.</p>

<form asp-action="Track" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label for="orderCode">Mã đơn hàng</label>
        <input type="text" id="orderCode" name="orderCode" class="form-control" placeholder="VD: ABCDEF1234" required />
    </div>
    <button type="submit" class="btn btn-primary mt-2">Xem trạng thái</button>
</form>

