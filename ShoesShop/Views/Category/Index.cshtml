@model IEnumerable<ProductModel>
<div class="col-sm-3">
    @Html.Partial("_SidebarPartial")
</div>
<style>
    .product-image-wrapper {
        height: 450px;
    }</style>
<!-- Features Items bên phải -->
<div class="col-sm-9 padding-right">
    <div class="features_items">
        <h2 class="title text-center">Features Items</h2>
        @foreach (var item in Model)
        {
            <div class="col-sm-4">
                <div class="product-image-wrapper">
                    <a>
                        <div class="single-products">
                            <div class="productinfo text-center">
                                <img src="~/media/products/@item.Image" alt="@item.Name" width="100%" />
                                <h2>@item.Price.ToString("#,#00 VNĐ")</h2>
                                <p>@item.Name</p>
                                <p>Danh mục: @item.Category.Name</p>
                                <p>Thương hiệu: @item.Brand.Name</p>
                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    @if (item.Quantity > 0)
                                    {
                                        <button class="btn btn-default add-to-cart " data-product_id="@item.Id"><i class="fa fa-shopping-cart"></i>Thêm giỏ hàng</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-default"><i class="fa fa-shopping-cart"></i>Hết hàng</button>
                                    }
                                }
                            </div>
                        </div>
                    </a>
                    <div class="choose text-center mt-3">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <ul class="nav nav-pills nav-justified">
                                <li>
                                    <button class="btn btn-outline-danger add-btn-wishlist" data-product_id="@item.Id">
                                        <i class="fa fa-heart"></i> Thêm vào yêu thích
                                    </button>
                                </li>
                            </ul>
                        }
                    </div>

                    <style>
                        .add-btn-wishlist {
                            transition: all 0.3s ease;
                            font-weight: 500;
                            border-radius: 30px;
                            padding: 8px 20px;
                        }

                            .add-btn-wishlist:hover {
                                background-color: #dc3545;
                                color: white;
                                transform: scale(1.05);
                                box-shadow: 0 4px 10px rgba(220, 53, 69, 0.4);
                            }

                            .add-btn-wishlist i {
                                margin-right: 6px;
                            }
                    </style>
                </div>
            </div>

        }

    </div><!--/features_items-->
</div>
</div>
