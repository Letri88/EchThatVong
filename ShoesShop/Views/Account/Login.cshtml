@model LoginViewModel
@{
    ViewData["title"] = "Đăng nhập";
}

<link href="~/css/account.css" rel="stylesheet" />

<div class="account-page-wrapper">
    <div class="account-card animate-fade-up">
        <div class="account-header">
            <h2>Đăng nhập</h2>
        </div>
        <div class="account-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="Login" asp-controller="Account">
                <div class="form-group mb-4">
                    <label>Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập của bạn..." />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-4">
                    <label>Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu..." />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary-custom">Đăng nhập</button>
                </div>

                <div class="account-footer">
                    <a asp-action="ForgetPassword" asp-controller="Account">Quên mật khẩu?</a>
                    <hr />
                     <a asp-action="LoginByGoogle" asp-controller="Account" class="btn btn-danger btn-block" style="color:white; border-radius:25px;">
                        <i class="fa fa-google"></i> Đăng nhập với Google
                    </a>
                    <p class="mt-3">Chưa có tài khoản? <a asp-action="Create" asp-controller="Account">Đăng ký ngay</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
