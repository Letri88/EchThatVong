@model UserModel
@{
    ViewData["title"] = "Đăng ký";
}

<link href="~/css/account.css" rel="stylesheet" />

<div class="account-page-wrapper">
    <div class="account-card animate-fade-up">
        <div class="account-header">
            <h2>Đăng ký tài khoản</h2>
        </div>
        <div class="account-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="Create" asp-controller="Account">
                <div class="form-group mb-4">
                    <label>Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control" placeholder="Chọn tên đăng nhập..." />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label>Email</label>
                    <input asp-for="Email" class="form-control" placeholder="Nhập địa chỉ email..." />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-4">
                    <label>Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Tạo mật khẩu..." />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary-custom">Đăng ký</button>
                </div>

                <div class="account-footer">
                    <p class="mt-3">Đã có tài khoản? <a asp-action="Login" asp-controller="Account">Đăng nhập ngay</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
