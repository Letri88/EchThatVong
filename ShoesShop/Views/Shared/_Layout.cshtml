	@if (User.Identity != null && User.Identity.IsAuthenticated)
	{
		<script>
		$(function () {
			// AI Chat widget
			const $fab = $('#ai-chat-fab');
			const $widget = $('#ai-chat-widget');
			const $body = $('#ai-chat-body');
			const $close = $('#ai-chat-close');
			const $minimize = $('#ai-chat-minimize');
			const $messages = $('#ai-chat-messages');
			const $imagePreview = $('#ai-image-preview');
			let lastMessageId = 0;
			let shopPollTimer = null;
			let pendingShopEcho = null;
			let pendingPreviewUrl = null;

			function addMessage(text, type, imagePath) {
				const cssClass = type === 'user' ? 'msg-user' : 'msg-bot';
				const $msg = $('<div/>').addClass('ai-msg').addClass(cssClass);
				if (text) {
					$msg.append($('<div/>').text(text));
				}
				if (imagePath) {
					const $img = $('<img/>', {
						src: imagePath,
						alt: 'Ảnh đính kèm',
						class: 'ai-chat-image'
					});
					$msg.append($img);
				}
				$messages.append($msg);
				$messages.scrollTop($messages[0].scrollHeight);
			}

			function openChat() {
				$widget.removeClass('ai-chat-hidden').addClass('ai-chat-open');
				$body.removeClass('ai-chat-collapsed');
				const mode = $('input[name="chatMode"]:checked').val();
				if (mode === 'shop') {
					startShopPolling();
				}
			}

			function closeChat() {
				$widget.removeClass('ai-chat-open').addClass('ai-chat-hidden');
				stopShopPolling();
			}

			$fab.on('click', function () {
				if ($widget.hasClass('ai-chat-open')) {
					closeChat();
				} else {
					openChat();
				}
			});

			$close.on('click', function () {
				closeChat();
			});

			$minimize.on('click', function () {
				$body.toggleClass('ai-chat-collapsed');
			});

			function renderShopMessages(messages) {
				if (!messages || !messages.length) return;
				messages.forEach(function (m) {
					if (m.id > lastMessageId) {
						// Tránh trùng tin nhắn vừa gửi (UI đã render optimistic)
						if (!m.isFromAdmin && pendingShopEcho) {
							const sameText = (m.message || '') === (pendingShopEcho.text || '');
							const hasServerImage = !!(m.imagePath && m.imagePath.length);
							const expectImage = !!pendingShopEcho.hasImage;
							const sameImage =
								(!expectImage && !hasServerImage) ||
								(expectImage && hasServerImage) ||
								((m.imagePath || '') === (pendingShopEcho.imagePath || ''));

							if (sameText && sameImage) {
								lastMessageId = m.id;
								pendingShopEcho = null;
								return;
							}
						}

						lastMessageId = m.id;
						addMessage(m.message || '', m.isFromAdmin ? 'bot' : 'user', m.imagePath);
					}
				});
			}

			function fetchShopMessages() {
				$.get('@Url.Action("GetConversation", "Chat")', function (res) {
					if (res && res.success && Array.isArray(res.messages)) {
						renderShopMessages(res.messages);
					}
				});
			}

			function startShopPolling() {
				if (shopPollTimer) return;
				// Lấy toàn bộ lịch sử lần đầu
				lastMessageId = 0;
				$messages.empty();
				pendingShopEcho = null;
				fetchShopMessages();
				shopPollTimer = setInterval(fetchShopMessages, 3000);
			}

			function stopShopPolling() {
				if (shopPollTimer) {
					clearInterval(shopPollTimer);
					shopPollTimer = null;
				}
			}

			// Ẩn/hiện field cho bot khi đổi mode
			$('input[name="chatMode"]').on('change', function () {
				const mode = $(this).val();
				if (mode === 'shop') {
					$('.ai-bot-fields').hide();
					$('.ai-shop-upload').show();
					startShopPolling();
				} else {
					$('.ai-bot-fields').show();
					$('.ai-shop-upload').hide();
					clearSelectedImage(false);
					stopShopPolling();
					loadBotHistory();
				}
			});

			// Clear preview UI; optionally keep selected file
			function clearSelectedImage(keepFile) {
				const fileInput = document.getElementById('ai-image');
				if (!keepFile && fileInput) fileInput.value = '';
				if (pendingPreviewUrl) {
					URL.revokeObjectURL(pendingPreviewUrl);
					pendingPreviewUrl = null;
				}
				$imagePreview.hide().empty();
			}

			// Preview ảnh trước khi gửi (chỉ dùng cho shop)
			$('#ai-image').on('change', function () {
				// Xóa preview cũ nhưng KHÔNG xóa file vừa chọn
				clearSelectedImage(true);
				const fileInput = document.getElementById('ai-image');
				if (!fileInput || !fileInput.files || fileInput.files.length === 0) return;

				const file = fileInput.files[0];
				pendingPreviewUrl = URL.createObjectURL(file);
				$imagePreview.html(
					'<div class="ai-preview-chip" title="Ảnh đã chọn">'
					+ '<img src="' + pendingPreviewUrl + '" class="ai-preview-thumb" alt="Xem trước ảnh" />'
					+ '<button type="button" class="ai-preview-remove" aria-label="Bỏ ảnh"><i class="fa fa-times"></i></button>'
					+ '</div>'
				).show();
			});

			$(document).on('click', '.ai-preview-remove', function () {
				clearSelectedImage(false);
			});

			function loadBotHistory() {
				$messages.empty();
				$.get('@Url.Action("GetBotConversation", "Chat")', function (res) {
					if (res && res.success && Array.isArray(res.messages)) {
						res.messages.forEach(function (m) {
							// If message contains html (like product images), we append html, else text
							if(m.message.indexOf('<') !== -1) {
								const cssClass = m.role === 'user' ? 'msg-user' : 'msg-bot';
								const $msg = $('<div/>').addClass('ai-msg').addClass(cssClass);
								$msg.append($('<div/>').html(m.message));
								$messages.append($msg);
							} else {
								addMessage(m.message || '', m.role === 'bot' ? 'bot' : 'user', null);
							}
						});
						$messages.scrollTop($messages[0].scrollHeight);
					}
				});
				// Tải danh sách câu hỏi theo mặc định (root)
				loadQuickReplies(null);
			}

			function loadQuickReplies(parentId) {
				const $quickReplies = $('#ai-quick-replies');
				$quickReplies.empty().hide();
				
				let url = '@Url.Action("GetBotQuestions", "Chat")';
				if(parentId) url += '?parentId=' + parentId;

				$.get(url, function(res) {
					if (res && res.success && res.questions && res.questions.length > 0) {
						renderQuickReplies(res.questions, null);
					}
				});
			}

			function renderQuickReplies(questions, categories) {
				const $quickReplies = $('#ai-quick-replies');
				$quickReplies.empty();
				let hasItem = false;

				if (questions && questions.length > 0) {
					questions.forEach(q => {
						const $btn = $('<button type="button" class="btn btn-sm btn-outline-warning" style="border-radius:20px; font-size:12px; padding:3px 10px;"/>')
							.text(q.userMessage)
							.on('click', function() {
								handleQuestionClick(q.id, q.userMessage);
							});
						$quickReplies.append($btn);
						hasItem = true;
					});
				}

				if (categories && categories.length > 0) {
					categories.forEach(c => {
						const $btn = $('<button type="button" class="btn btn-sm btn-outline-info" style="border-radius:20px; font-size:12px; padding:3px 10px;"/>')
							.text(c.name)
							.on('click', function() {
								handleCategoryClick(c.id, c.name);
							});
						$quickReplies.append($btn);
						hasItem = true;
					});
				}

				if(hasItem) {
					$quickReplies.css('display', 'flex');
				} else {
					$quickReplies.hide();
					loadQuickReplies(null); // Return to root if dead end
				}
			}

			function handleQuestionClick(id, text) {
				$('#ai-quick-replies').empty().hide();
				addMessage(text, 'user', null);
				
				$.ajax({
					url: '@Url.Action("ProcessBotQuestion", "Chat")',
					method: 'POST',
					contentType: 'application/json',
					data: JSON.stringify(id),
					success: function (res) {
						if (res && res.success) {
							addMessage(res.message, 'bot', null);
							renderQuickReplies(res.nextQuestions, res.categories);
						}
					}
				});
			}

			function handleCategoryClick(id, text) {
				$('#ai-quick-replies').empty().hide();
				addMessage('Xem danh mục: ' + text, 'user', null);
				
				$.ajax({
					url: '@Url.Action("ProcessCategoryOption", "Chat")',
					method: 'POST',
					contentType: 'application/json',
					data: JSON.stringify(id),
					success: function (res) {
						if (res && res.success) {
							const $msg = $('<div/>').addClass('ai-msg').addClass('msg-bot');
							$msg.append($('<div/>').html(res.message));
							$messages.append($msg);
							$messages.scrollTop($messages[0].scrollHeight);
							
							// Sau khi show SP thì quay lại root question
							loadQuickReplies(null);
						}
					}
				});
			}

			$('#ai-send-btn').on('click', function () {
				const fullName = $('#ai-fullname').val();
				const birthDate = $('#ai-birthdate').val();
				const gender = $('#ai-gender').val();
				const messageText = $('#ai-message').val().trim();
				const mode = $('input[name="chatMode"]:checked').val();
				const fileInput = document.getElementById('ai-image');
				const hasImage = fileInput && fileInput.files && fileInput.files.length > 0;

				if (mode === 'bot') {
					if (!messageText) {
						Swal.fire('Vui lòng nhập yêu cầu của bạn.');
						return;
					}
				} else {
					if (!messageText && !hasImage) {
						Swal.fire('Vui lòng nhập nội dung hoặc chọn hình.');
						return;
					}
				}

				// Nếu có ảnh đã chọn thì dùng preview đang hiển thị
				const previewImageUrl = hasImage ? (pendingPreviewUrl || URL.createObjectURL(fileInput.files[0])) : null;
				addMessage(messageText, 'user', previewImageUrl);
				$('#ai-message').val('');

				if (mode === 'bot') {
					$.ajax({
						url: '@Url.Action("Suggest", "Chat")',
						method: 'POST',
						contentType: 'application/json',
						data: JSON.stringify({
							fullName: fullName,
							birthDate: birthDate || null,
							gender: gender,
							message: messageText
						}),
						success: function (res) {
							if (res && res.success) {
								addMessage(res.message, 'bot', null);
							} else {
								addMessage('Xin lỗi, hệ thống không trả lời được. Vui lòng thử lại sau.', 'bot', null);
							}
						},
						error: function () {
							addMessage('Có lỗi khi kết nối tới máy chủ. Vui lòng thử lại sau.', 'bot', null);
						}
					});
				} else {
					// Chat với shop
					// Mark as pending to avoid echo duplicate when polling returns the same message
					pendingShopEcho = {
						text: messageText || '',
						hasImage: hasImage,
						imagePath: ''
					};

					const formData = new FormData();
					formData.append('FullName', fullName);
					formData.append('BirthDate', birthDate || '');
					formData.append('Gender', gender || '');
					formData.append('Message', messageText);

					if (hasImage) {
						formData.append('image', fileInput.files[0]);
						// Xóa preview sau khi gửi
						clearSelectedImage(false);
					}

					$.ajax({
						url: '@Url.Action("SendToShop", "Chat")',
						method: 'POST',
						processData: false,
						contentType: false,
						data: formData,
						success: function (res) {
							if (!res || !res.success) {
								addMessage('Không gửi được tin nhắn cho shop, vui lòng thử lại.', 'bot', null);
								pendingShopEcho = null;
							} else {
								// Fetch nhanh để đồng bộ lastMessageId
								fetchShopMessages();
							}
						},
						error: function () {
							addMessage('Không gửi được tin nhắn cho shop, vui lòng thử lại.', 'bot', null);
							pendingShopEcho = null;
						}
					});
				}
			});

			// Load bot history lần đầu (mode mặc định là bot)
			loadBotHistory();
		});
		</script>
	}
	@await RenderSectionAsync("Scripts", required: false)

