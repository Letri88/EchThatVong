	<style>
		/* Chỉ hiện trên Mobile */
		@@media (min-width: 768px) {
			#global-mobile-drawer, #global-sidebar-overlay {
				display: none !important;
			}
		}

		/* Styling cho Mobile Drawer */
		@@media (max-width: 767px) {
			.global-mobile-drawer {
				position: fixed;
				top: 0;
				left: 0;
				width: 85%;
