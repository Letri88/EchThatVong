				font-weight: 600;
				text-transform: uppercase;
			}

			.close-drawer {
				background: transparent;
				border: none;
				color: #ffffff;
				font-size: 22px;
				cursor: pointer;
			}

			.drawer-body {
				flex: 1;
				overflow-y: auto;
				padding: 15px;
			}

			.drawer-section {
				margin-bottom: 25px;
			}

			.drawer-section h2 {
				color: #FE980F;
				font-size: 16px;
				font-weight: 600;
				text-transform: uppercase;
				border-bottom: 2px solid #FE980F;
				padding-bottom: 8px;
				margin-bottom: 12px;
				margin-top: 5px;
			}

			/* Danh sách Menu Nội Bộ */
			.drawer-nav {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.drawer-nav li {
				margin-bottom: 10px;
			}

			.drawer-nav a {
				color: #555;
				font-size: 15px;
				font-weight: 500;
				text-decoration: none;
				display: block;
				padding: 8px 10px;
				border-radius: 4px;
				transition: background 0.2s, color 0.2s;
			}

			.drawer-nav a:hover, .drawer-nav a:focus {
				background-color: #fffcf8;
				color: #FE980F;
			}
			
			.drawer-nav i {
				margin-right: 10px;
				width: 16px;
				text-align: center;
				color: #aaa;
			}

			/* Định dạng lại Panel của VC nội bộ */
			.drawer-section .panel {
				border: none;
				box-shadow: none;
				background: transparent;
				border-radius: 0;
				margin-top: 0;
			}

			.drawer-section .panel-heading {
				background: transparent;
				padding: 10px 10px;
				border: none;
			}

			.drawer-section .panel-title a {
				color: #555;
				font-size: 14.5px;
				font-weight: 500;
				text-decoration: none;
				display: block;
				transition: color 0.2s;
			}
			
			.drawer-section .panel-title a:hover {
				color: #FE980F;
			}

			.sidebar-overlay {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 100vh;
				background: rgba(0, 0, 0, 0.4);
				z-index: 1040;
				display: none;
				opacity: 0;
				transition: opacity 0.3s ease;
			}

			.sidebar-overlay.overlay-active {
				display: block;
				opacity: 1;
			}

			body.drawer-no-scroll {
				overflow: hidden;
			}
		}
	</style>

	<script>
		document.addEventListener("DOMContentLoaded", function() {
			const toggleBtn = document.getElementById('global-mobile-menu-toggle');
			const closeBtn = document.getElementById('close-drawer-btn');
			const drawer = document.getElementById('global-mobile-drawer');
			const overlay = document.getElementById('global-sidebar-overlay');
			const body = document.body;

			if (!drawer || !toggleBtn) return; // Không chạp script nếu element không tồn tại

			function openDrawer() {
				drawer.classList.add('drawer-open');
				overlay.classList.add('overlay-active');
				body.classList.add('drawer-no-scroll');
			}

			function closeDrawer() {
				drawer.classList.remove('drawer-open');
				overlay.classList.remove('overlay-active');
				body.classList.remove('drawer-no-scroll');
			}

			// Gắn sự kiện
			toggleBtn.addEventListener('click', function(e) {
				e.preventDefault();
				openDrawer();
			});
			
			if (closeBtn) {
				closeBtn.addEventListener('click', closeDrawer);
			}

			if (overlay) {
				overlay.addEventListener('click', closeDrawer);
			}
		});
	</script>
	</div>
</body>
