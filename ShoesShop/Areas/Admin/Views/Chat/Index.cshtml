@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Hộp thư chat khách hàng";
  
}

<div class="admin-chat-shell">
    <div class="admin-chat-list">
        <div class="admin-chat-list-header">
            <div class="admin-chat-list-title">Hộp thư</div>
            <div class="admin-chat-list-sub">Tin nhắn khách hàng</div>
        </div>

        <div class="admin-chat-search">
            <i class="fa fa-search"></i>
            <input type="text" class="form-control" placeholder="Tìm theo tên khách..." disabled />
        </div>

        <div class="admin-chat-items">
            @foreach (var c in Model)
            {
                var name = (string)(c.UserName ?? "Khách");
                var initials = string.IsNullOrWhiteSpace(name) ? "?" : name.Trim().Substring(0, 1).ToUpper();
                <a class="admin-chat-item" asp-action="Thread" asp-route-id="@c.ConversationId">
                    <div class="admin-chat-avatar">@initials</div>
                    <div class="admin-chat-item-body">
                        <div class="admin-chat-item-top">
                            <div class="admin-chat-item-name">@name</div>
                            <div class="admin-chat-item-time">@c.LastMessageTime.ToString("HH:mm dd/MM")</div>
                        </div>
                        <div class="admin-chat-item-preview">@c.LastMessage</div>
                    </div>
                </a>
            }
        </div>
    </div>

    <div class="admin-chat-empty">
        <div class="admin-chat-empty-card">
            <i class="fa fa-comments-o"></i>
            <div class="admin-chat-empty-title">Chọn một cuộc trò chuyện</div>
            <div class="admin-chat-empty-sub">Bạn sẽ thấy tin nhắn của khách ở đây.</div>
        </div>
    </div>
</div>

<style>
    .admin-chat-shell {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 18px;
        min-height: 70vh;
    }

    .admin-chat-list {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.06);
    }

    .admin-chat-list-header {
        padding: 14px 14px 8px;
        border-bottom: 1px solid rgba(0,0,0,0.06);
    }

    .admin-chat-list-title {
        font-weight: 800;
        font-size: 18px;
        color: #111;
    }

    .admin-chat-list-sub {
        font-size: 12px;
        color: #6b7280;
        margin-top: 2px;
    }

    .admin-chat-search {
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        border-bottom: 1px solid rgba(0,0,0,0.06);
        color: #9ca3af;
    }

    .admin-chat-search .form-control {
        border-radius: 999px;
        border: 1px solid rgba(0,0,0,0.08);
        box-shadow: none;
    }

    .admin-chat-items {
        max-height: calc(70vh - 110px);
        overflow-y: auto;
    }

    .admin-chat-item {
        display: flex;
        gap: 12px;
        padding: 12px 14px;
        text-decoration: none;
        border-bottom: 1px solid rgba(0,0,0,0.04);
    }

    .admin-chat-item:hover {
        background: rgba(47,124,246,0.06);
        text-decoration: none;
    }

    .admin-chat-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #6c5ce7;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        flex: 0 0 auto;
    }

    .admin-chat-item-body {
        min-width: 0;
        flex: 1;
    }

    .admin-chat-item-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 10px;
    }

    .admin-chat-item-name {
        font-weight: 700;
        color: #111;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .admin-chat-item-time {
        font-size: 11px;
        color: #6b7280;
        flex: 0 0 auto;
    }

    .admin-chat-item-preview {
        margin-top: 2px;
        font-size: 12px;
        color: #6b7280;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .admin-chat-empty {
        background: #fff;
        border-radius: 14px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .admin-chat-empty-card {
        text-align: center;
        color: #6b7280;
        padding: 24px;
    }

    .admin-chat-empty-card i {
        font-size: 44px;
        color: rgba(47,124,246,0.35);
        margin-bottom: 10px;
    }

    .admin-chat-empty-title {
        font-size: 16px;
        font-weight: 800;
        color: #111;
    }

    .admin-chat-empty-sub {
        margin-top: 4px;
        font-size: 12px;
    }

    @@media (max-width: 991px) {
        .admin-chat-shell {
            grid-template-columns: 1fr;
        }
        .admin-chat-empty {
            display: none;
        }
    }
</style>

