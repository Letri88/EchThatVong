@model ShoesShop.Models.CouponModel
@{
    ViewData["Title"] = "Phiếu giảm giá";
}
<h3 class="mb-4">Tạo phiếu giảm giá</h3>

<div class="col-md-9">
    <h4 class="mb-4">@ViewData["Title"]</h4>

    <form autocomplete="off" asp-controller="Coupon" asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Tên phiếu -->
        <div class="form-group mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="VD: GIAM20K" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <!-- Mô tả -->
        <div class="form-group mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn gọn về phiếu..."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <!-- Ngày bắt đầu & kết thúc -->
        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="DateStart" class="form-label">Ngày bắt đầu</label>
                    <input asp-for="DateStart" class="form-control datepicker" id="datepicker1" placeholder="dd/mm/yyyy" />
                    <span asp-validation-for="DateStart" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="DateEnd" class="form-label">Ngày hết hạn</label>
                    <input asp-for="DateEnd" class="form-control datepicker" id="datepicker2" placeholder="dd/mm/yyyy" />
                    <span asp-validation-for="DateEnd" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Số lượng -->
        <div class="form-group mb-3">
            <label asp-for="Quantity" class="form-label">Số lượng sử dụng</label>
            <input asp-for="Quantity" type="number" min="1" class="form-control" value="1" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <!-- Loại giảm giá -->
        <div class="form-group mb-3">
            <label class="form-label">Loại giảm giá</label>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="IsPercentage" id="percentRadio" value="true" checked="@(Model?.IsPercentage == true)" />
                <label class="form-check-label" for="percentRadio">Giảm theo %</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="IsPercentage" id="fixedRadio" value="false" checked="@(Model?.IsPercentage == false)" />
                <label class="form-check-label" for="fixedRadio">Giảm cố định (₫)</label>
            </div>
        </div>

        <!-- Giá trị giảm -->
        <div class="form-group mb-3">
            <label asp-for="DiscountValue" class="form-label">
                Giá trị giảm <span id="discountUnit">(%)</span>
            </label>
            <input asp-for="DiscountValue" type="number" min="0" step="0.01" class="form-control" placeholder="VD: 20 hoặc 50000" />
            <span asp-validation-for="DiscountValue" class="text-danger"></span>
        </div>

        <!-- Đơn hàng tối thiểu -->
        <div class="form-group mb-3">
            <label asp-for="MinOrderAmount" class="form-label">Đơn hàng tối thiểu (₫)</label>
            <input asp-for="MinOrderAmount" type="number" min="0" class="form-control" placeholder="0 = Không yêu cầu" />
            <small class="text-muted">Để trống hoặc 0 nếu không yêu cầu</small>
            <span asp-validation-for="MinOrderAmount" class="text-danger"></span>
        </div>

        <!-- Mỗi user dùng 1 lần -->
        <div class="form-group mb-3">
            <div class="form-check">
                <input asp-for="IsOneTimePerUser" class="form-check-input" type="checkbox" id="oneTimeCheck" />
                <label class="form-check-label" for="oneTimeCheck">
                    Mỗi khách hàng chỉ dùng được 1 lần
                </label>
            </div>
        </div>

        <!-- Trạng thái -->
        <div class="form-group mb-4">
            <label asp-for="Status" class="form-label">Trạng thái</label>
            <select asp-for="Status" class="form-select">
                <option value="1">Kích hoạt ngay</option>
                <option value="0">Ẩn (lưu nháp)</option>
            </select>
        </div>

        <!-- Nút submit -->
        <div class="form-group">
            <button type="submit" class="btn btn-primary me-2">
                <i class="fas fa-save"></i> Tạo phiếu giảm giá
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </form>
</div>
    <hr />

<div class="table-responsive mt-3">
    <table class="table table-striped table-hover" id="couponTable">
        <thead class="table-dark">
            <tr>
                <th>Tên phiếu</th>
                <th>Mô tả</th>
                <th>Ngày bắt đầu</th>
                <th>Ngày hết hạn</th>
                <th>Số lượng</th>
                <th>Loại giảm</th>
                <th>Giá trị giảm</th>
                <th>Đơn tối thiểu</th>
                <th>Mỗi user 1 lần</th>
                <th>Trạng thái</th>
                <th>Thời gian còn lại</th>
            </tr>
        </thead>
        <tbody>
            @{
                var coupons = ViewBag.Coupons as IEnumerable<ShoesShop.Models.CouponModel>;
            }
            @if (coupons != null && coupons.Any())
            {
                foreach (var coupon in coupons)
                {
                    <tr>
                        <td>@coupon.Name</td>
                        <td>@coupon.Description</td>
                        <td>@coupon.DateStart:dd-MM-yyyy</td>
                        <td>@coupon.DateEnd:dd-MM-yyyy</td>
                        <td>@coupon.Quantity</td>
                        <td>@(coupon.IsPercentage ? "Giảm theo %" : "Giảm cố định")</td>
                        <td>
                            @(coupon.IsPercentage 
                                ? $"{coupon.DiscountValue}%" 
                                : $"{coupon.DiscountValue:N0}₫")
                        </td>
                        <td>
                            @(coupon.MinOrderAmount.HasValue 
                                ? $"{coupon.MinOrderAmount.Value:N0}₫" 
                                : "Không yêu cầu")
                        </td>
                        <td class="text-center">
                            <span class="badge @(coupon.IsOneTimePerUser ? "bg-success" : "bg-secondary")">
                                @(coupon.IsOneTimePerUser ? "Yes" : "No")
                            </span>
                        </td>
                        <td>
                            <select class="form-select form-select-sm status-dropdown" data-id="@coupon.Id">
                                    <option value="1" selected="@(coupon.Status == 1)">Kích hoạt</option>
                                    <option value="0" selected="@(coupon.Status == 0)">Ẩn</option>
                            </select>
                        </td>
                        <td>
                            @{
                                var now = DateTime.Now;
                                var remaining = coupon.DateEnd - now;
                            }
                            @if (coupon.DateEnd < now)
                            {
                                <span class="badge bg-danger">Đã hết hạn</span>
                            }
                            else if (remaining.Days == 0)
                            {
                                var hours = remaining.Hours;
                                var minutes = remaining.Minutes;
                                <span class="badge bg-warning text-dark">
                                    @(hours > 0 ? $"{hours}h {minutes}p" : $"{minutes} phút")
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">@remaining.Days ngày còn lại</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="11" class="text-center text-muted py-4">
                        Không có phiếu giảm giá nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(function () {
            $("#datepicker").datepicker({
                changeYear: true,
                minDate: 0,
                showButtonPanel: true,
                dateFormat: 'dd/mm/yy'

            });

        });
        $(function () {
            $("#datepicker2").datepicker({
                changeYear: true,
                minDate: +1,
                showButtonPanel: true,
                dateFormat: 'dd/mm/yy'

            });

        });
        // Cập nhật trạng thái phiếu giảm giá
        $(document).ready(function () {
            $(".status-dropdown").change(function () {
                var id = $(this).data("id");
                var newStatus = $(this).val();

                $.ajax({
                    url: '/Admin/Coupon/UpdateStatus',
                    type: 'POST',
                    data: { id: id, status: newStatus },
                    success: function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: "success",
                                title: "Đã cập nhật trạng thái",
                                timer: 1500,
                                showConfirmButton: false
                            });
                        } else {
                            Swal.fire({
                                icon: "error",
                                title: "Lỗi",
                                text: res.message || "Không thể cập nhật trạng thái"
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            icon: "error",
                            title: "Lỗi máy chủ",
                            text: "Không thể kết nối đến server"
                        });
                    }
                });
            });
        });
    </script>
}
