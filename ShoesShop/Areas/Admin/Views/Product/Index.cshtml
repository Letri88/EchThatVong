@model IEnumerable<ProductModel>
@{
    ViewData["title"] = "Product List";
    Paginate pager = new Paginate();
    int pageNo = 0;
    if(ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.CurrentPage;
    }
}
<h3>List Product</h3>
<a class="btn btn-primary"  asp-area="Admin" asp-action="Create" asp-controller="Product">Thêm sản phẩm</a>

<table class="table" id="myTable">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Tên sản phẩm</th>
            <th scope="col">Số lượng sản phẩm</th>
            <th scope="col">Đã bán hết</th>
            <th scope="col">Mô tả</th>
            <th scope="col">Giá</th>
            <th scope="col">Giá vốn</th>
            <th scope="col">Hình ảnh</th>
            <th scope="col">Slug</th>
            <th scope="col">Danh mục</th>
            <th scope="col">Thương hiệu</th>
            <th scope="col">Hành động</th>
        </tr>
    </thead>

    <tbody>
        @foreach(var item in Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td><b>@item.Quantity</b><br /><a asp-controller="Product" asp-action="AddQuantity" asp-route-Id="@item.Id">Thêm số lượng</a></td>
                <td><b>@item.Sold</b></td>
                <td>@Html.Raw(@item.Description)</td>
                <td>@item.Price.ToString("#,#00 VNĐ")</td>
                <td>@item.Capital.ToString("#,#00 VNĐ")</td>
                <td> <img src="~/media/products/@item.Image" width="120px" height="150px" /> </td>
                 <td>@item.Slug</td>
                <td>@item.Category.Name</td>
                 <td>@item.Brand.Name</td>
                <td>
                    <a asp-area="Admin" asp-action="Edit" class="btn btn-warning btn-sm" asp-controller="Product" asp-route-Id="@item.Id">Sửa</a>
                    <a asp-area="Admin" asp-action="Delete" class="btn btn-danger btn-sm confirmDeletion" asp-controller="Product" asp-route-Id="@item.Id">Xóa</a>
                </td>
            </tr>
        }
      
    </tbody>
</table>
<partial name="_paging" model ="@pager" />
@section Scripts {
    <script>
        let table = new DataTable('#myTable');
    </script>
}