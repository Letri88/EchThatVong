@model AppUserModel
@{
    ViewData["title"] = "Sửa người dùng";
}
<h4>Thêm danh mục</h4>
<div class="col-md-9">
    <form asp-action="Edit" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"> </div>
        <div class="form-group">
            <label>Tên người dùng</label>
            <input asp-for="UserName" required class="form-control" />
            <span asp-validation-for="UserName" class="text-danger" />
        </div>
        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" required class="form-control" />
            <span asp-validation-for="Email" class="text-danger" />
        </div>
        <div class="form-group">
            <label>Số điện thoại</label>
            <input asp-for="PhoneNumber" required class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger" />
        </div>
        <div class="form-group">
            <label>Mật khẩu</label>
            <input asp-for="PasswordHash" readonly class="form-control" />
            <span asp-validation-for="PasswordHash" class="text-danger" />
        </div>
        @*<div class="form-group">
        <label>Phân quyền</label>
        <select asp-for="RoleId" class="form-control">
        <option value="1">Hiển thị</option>
        <option value="0">Ẩn</option>
        </select>
        <span asp-validation-for="Status" class="text-danger" />
        </div>
        *@
        <div class="form-group">
            <button class="btn btn-primary">Cập nhật</button>
        </div>
    </form>
    <a asp-action="Index">Trở lại trang người dùng</a>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
